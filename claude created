local function setDescriptionsVisible(visible)
	for _, card in ipairs(ScriptsContainer:GetChildren()) do
		if card:IsA("Frame") then
			local desc = card:FindFirstChild("Description")
			if desc then
				desc.Visible = visible
			end
		end
	end
end

